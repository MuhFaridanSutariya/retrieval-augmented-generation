ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_VERBOSE=false

API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge_assistant
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

REDIS_URL=redis://localhost:6379/0
RESPONSE_CACHE_TTL_SECONDS=3600
EMBEDDING_CACHE_TTL_SECONDS=2592000

OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-5.4-2026-03-05
OPENAI_CHAT_TEMPERATURE=0.0
OPENAI_CHAT_MAX_OUTPUT_TOKENS=800
OPENAI_CHAT_TIMEOUT_SECONDS=30
OPENAI_CHAT_MAX_RETRIES=3
OPENAI_CHAT_INPUT_USD_PER_1M=2.50
OPENAI_CHAT_OUTPUT_USD_PER_1M=15.00
OPENAI_CHAT_EXTENDED_CONTEXT_THRESHOLD_TOKENS=272000
OPENAI_CHAT_INPUT_EXTENDED_USD_PER_1M=5.00

OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_EMBEDDING_BATCH_SIZE=96
OPENAI_EMBEDDING_USD_PER_1M=0.13

FAISS_INDEX_PATH=data/index/faiss.index
FAISS_METADATA_PATH=data/index/metadata.json
FAISS_OVERSAMPLE_FACTOR=5

INTENT_CLASSIFICATION_THRESHOLD=0.55

CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
RETRIEVAL_TOP_K=8
RERANK_TOP_K=4
RERANK_ENABLED=true
RERANK_MAX_OUTPUT_TOKENS=100
HYBRID_CANDIDATE_MULTIPLIER=3
RRF_K=60
MIN_RELEVANCE_SCORE=0.1
MAX_CONTEXT_TOKENS=8000
TOKEN_BUDGET_SAFETY_PAD=10

UPLOAD_MAX_BYTES=26214400
UPLOAD_ALLOWED_EXTENSIONS=pdf,txt,md
